// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Domain {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  status      String   @default("ACTIVE")
  environment String   @default("PRODUCTION")
  owner       String
  team        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subdomains Subdomain[]
  requests   DomainRequest[]
  auditLogs  AuditLog[]
}

model Subdomain {
  id          String   @id @default(cuid())
  name        String
  fullDomain  String   @unique
  description String?
  purpose     String   @default("OTHER")
  status      String   @default("ACTIVE")
  environment String   @default("PRODUCTION")
  targetIP    String?
  sslEnabled  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  domainId  String
  domain    Domain          @relation(fields: [domainId], references: [id], onDelete: Cascade)
  requests  DomainRequest[]
  auditLogs AuditLog[]
}

model DomainRequest {
  id            String   @id @default(cuid())
  type          String
  status        String   @default("PENDING")
  priority      String   @default("MEDIUM")
  title         String
  description   String
  justification String?
  requestedBy   String
  requestedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // For new domain/subdomain requests
  proposedName        String?
  proposedEnvironment String?
  proposedPurpose     String?
  proposedDescription String?

  // For modifications
  currentValue  String?
  proposedValue String?

  domainId    String?
  domain      Domain?    @relation(fields: [domainId], references: [id])
  subdomainId String?
  subdomain   Subdomain? @relation(fields: [subdomainId], references: [id])

  approvals Approval[]
  comments  Comment[]
  auditLogs AuditLog[]
}

model Approval {
  id         String        @id @default(cuid())
  requestId  String
  request    DomainRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approvedBy String
  status     String
  comment    String?
  createdAt  DateTime      @default(now())
}

model Comment {
  id        String        @id @default(cuid())
  requestId String
  request   DomainRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author    String
  content   String
  createdAt DateTime      @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  performedBy String
  details     String?
  createdAt   DateTime @default(now())

  domainId    String?
  domain      Domain?        @relation(fields: [domainId], references: [id])
  subdomainId String?
  subdomain   Subdomain?     @relation(fields: [subdomainId], references: [id])
  requestId   String?
  request     DomainRequest? @relation(fields: [requestId], references: [id])
}
